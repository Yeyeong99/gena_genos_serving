{% if style_context and style_context.bilingual_summary_memory and (style_context.bilingual_summary_memory.get("raw_scopes") or style_context.bilingual_summary_memory.get("summaries") or style_context.bilingual_summary_memory.get("summary")) %}
{% set memory = style_context.bilingual_summary_memory %}
{% set summary = memory.get("summary") %}
DOCUMENT TRANSLATION MEMORY:
- Use this only to maintain continuity with earlier translated scopes.
- Do not copy this memory into the translation.
- This memory is lower priority than Document Term Memory.
- Never infer term translations from this memory.
- Use this memory only for discourse continuity, section flow, register, and style continuity.
- If this memory conflicts with Document Term Memory, follow Document Term Memory.
{% if memory.get("compression_enabled") %}
- Memory mode: cumulative compressed memory plus recent uncompressed source-target history.
- Approximate prompt memory budget: {{ memory.get("prompt_memory_budget_tokens") }} tokens.
{% else %}
- Memory mode: uncompressed source-target history.
{% endif %}
{% if summary and (summary.get("source_summary") or summary.get("target_summary") or summary.get("style_continuity") or summary.get("discourse_state") or summary.get("open_references")) %}
Compressed cumulative memory:
{% if summary.get("source_summary") %}
- previous source flow: {{ summary.get("source_summary") }}
{% endif %}
{% if summary.get("target_summary") %}
- previous target flow, for style and discourse only: {{ summary.get("target_summary") }}
{% endif %}
{% if summary.get("style_continuity") %}
- style continuity: {{ summary.get("style_continuity") }}
{% endif %}
{% if summary.get("discourse_state") %}
- discourse state: {{ summary.get("discourse_state") }}
{% endif %}
{% if summary.get("open_references") %}
- open references: {{ summary.get("open_references") | join(" / ") }}
{% endif %}
{% endif %}
{% if memory.get("raw_scopes") %}
- The following is recent uncompressed source-target history from completed earlier scopes.
- Use it to maintain local continuity; do not treat it as a glossary.
- raw memory size: {{ memory.get("raw_scope_count") }} scopes / {{ memory.get("raw_memory_word_count") }} source words / {{ memory.get("raw_memory_char_count") }} source-target characters.
{% for raw_scope in memory.get("raw_scopes") %}
Raw scope {{ loop.index }}{% if raw_scope.get("scope") %} ({{ raw_scope.get("scope") }}){% endif %}: {{ raw_scope.get("word_count") }} source words / {{ raw_scope.get("item_count") }} items
{% for item in raw_scope.get("items") or [] %}
- source: {{ item.get("source") }}
  target: {{ item.get("target") }}
{% endfor %}
{% endfor %}
{% endif %}

{% endif %}
