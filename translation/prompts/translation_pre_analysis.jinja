{% endfor %}

{% endif %}
{% if analysis.get("participants_and_roles") %}
PARTICIPANTS AND ROLES:
{% for entry in analysis.get("participants_and_roles") %}
- {{ entry.get("source", "") }}: {{ entry.get("document_local_role", "") }}{% if entry.get("evidence") %} | evidence: {{ entry.get("evidence") }}{% endif %}{{ "\n" }}
{% endfor %}
{% endif %}
{% if analysis.get("style_guidance") %}
STYLE GUIDANCE:
{% for item in analysis.get("style_guidance") %}
- {{ item }}
{% endfor %}

{% endif %}
